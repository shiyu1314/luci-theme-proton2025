# Proton2025 Theme Configuration
# This file stores theme settings that sync across browsers

config theme 'settings'
	option mode 'dark'
	option accent 'blue'
	option zoom '100'
	option transparency '1'
	option border_radius 'default'
	option animations '1'
	option services_widget '0'
	option temp_widget '0'
	option services_log '0'
	option table_wrap '1'
	option log_highlight '1'
	option page_width '0'
	option custom_font '1'

